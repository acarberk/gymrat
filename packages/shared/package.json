{
  "name": "@gymrat/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared types, Zod schemas, constants, and pure utilities between web and api",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "echo 'no tests yet'",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@gymrat/config": "workspace:*",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
